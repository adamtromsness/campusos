# ═══════════════════════════════════════════════════════════════
# CampusOS Environment Variables
# Copy to .env.local: cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════

# ── Database (PostgreSQL 16) ──────────────────────────────────
DATABASE_URL="postgresql://campusos:campusos_dev@localhost:5432/campusos_dev?schema=platform"

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS="localhost:9092"

# ── Auth (Keycloak) ───────────────────────────────────────────
OIDC_ISSUER="http://localhost:8080/realms/campusos"
OIDC_CLIENT_ID="campusos-api"
OIDC_CLIENT_SECRET="change-me-in-local"
JWT_SECRET="change-me-in-local-min-32-chars-long"

# ── API ───────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

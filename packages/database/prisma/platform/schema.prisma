// ═══════════════════════════════════════════════════════════════
// CampusOS Platform Schema — Prisma Definition
// Schema: platform (shared across all tenants via search_path)
//
// Step 4: Foundation (organisations, schools, tenant routing, audit)
// Step 5: Identity (iam_person, platform_users, students, families)
// Step 6: IAM (roles, permissions, assignments, cache)
// ═══════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["platform"]
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// STEP 4 — Foundation Tables
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ── Organisations ────────────────────────────────────────────
model Organisation {
  id          String   @id @db.Uuid
  name        String
  countryCode String?  @map("country_code") @db.Char(2)
  orgType     OrgType  @default(INDEPENDENT_GROUP) @map("org_type")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  schools School[]

  @@map("organisations")
  @@schema("platform")
}

enum OrgType {
  DISTRICT
  MAT
  INDEPENDENT_GROUP

  @@schema("platform")
}

// ── Schools ──────────────────────────────────────────────────
model School {
  id             String   @id @db.Uuid
  organisationId String?  @map("organisation_id") @db.Uuid
  name           String
  subdomain      String   @unique
  countryCode    String   @map("country_code") @db.Char(2)
  timezone       String
  planTier       PlanTier @default(SMALL) @map("plan_tier")
  schemaName     String   @map("schema_name")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  organisation Organisation?      @relation(fields: [organisationId], references: [id])
  routing      TenantRouting?
  idProviders  IdentityProvider[]

  @@index([subdomain])
  @@map("schools")
  @@schema("platform")
}

enum PlanTier {
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE

  @@schema("platform")
}

// ── Tenant Routing (ADR-031, ADR-042, ADR-044) ──────────────
model TenantRouting {
  id                 String    @id @db.Uuid
  tenantId           String    @unique @map("tenant_id") @db.Uuid
  clusterId          String    @default("primary") @map("cluster_id")
  schemaName         String    @map("schema_name")
  isActive           Boolean   @default(true) @map("is_active")
  isFrozen           Boolean   @default(false) @map("is_frozen")
  isMigrating        Boolean   @default(false) @map("is_migrating")
  migratedAt         DateTime? @map("migrated_at") @db.Timestamptz()
  maxConnectionsPool Int       @default(10) @map("max_connections_pool")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  school School @relation(fields: [tenantId], references: [id])

  @@map("platform_tenant_routing")
  @@schema("platform")
}

// ── Audit Log ────────────────────────────────────────────────
model AuditLog {
  id         String   @id @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  actorType  String   @default("HUMAN") @map("actor_type")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  tenantId   String?  @map("tenant_id") @db.Uuid
  metadata   Json?    @db.JsonB
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("platform_audit_log")
  @@schema("platform")
}

// ── Event Consumer Idempotency (ADR-057) ─────────────────────
model EventConsumerIdempotency {
  id            String   @id @db.Uuid
  consumerGroup String   @map("consumer_group")
  eventId       String   @map("event_id")
  topic         String
  processedAt   DateTime @default(now()) @map("processed_at") @db.Timestamptz()

  @@unique([consumerGroup, eventId])
  @@index([processedAt])
  @@map("platform_event_consumer_idempotency")
  @@schema("platform")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// STEP 5 — Identity Tables (ADR-036, ADR-055)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ── IAM Person — Universal Human Identity ────────────────────
// The canonical FK target for ALL domain references to a human.
// ADR-055: if the column identifies WHO a person IS → FK(iam_person)
// ADR-036: person can exist without a platform_users account
model IamPerson {
  id             String     @id @db.Uuid
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  preferredName  String?    @map("preferred_name")
  dateOfBirth    DateTime?  @map("date_of_birth") @db.Date
  nationalIdHash String?    @map("national_id_hash")
  personType     PersonType @map("person_type")
  isActive       Boolean    @default(true) @map("is_active")
  mergedIntoId   String?    @map("merged_into_id") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  mergedInto     IamPerson?  @relation("PersonMerge", fields: [mergedIntoId], references: [id])
  mergedFrom     IamPerson[] @relation("PersonMerge")
  account        PlatformUser?
  studentProfile PlatformStudent?
  familyMembers  FamilyMember[]
  volunteerProfile VolunteerProfile?
  substituteProfile SubstituteProfile?

  @@index([nationalIdHash])
  @@index([personType, isActive])
  @@index([mergedIntoId])
  @@map("iam_person")
  @@schema("platform")
}

enum PersonType {
  STAFF
  STUDENT
  GUARDIAN
  VOLUNTEER
  SUBSTITUTE
  ALUMNI
  EXTERNAL

  @@schema("platform")
}

// ── Platform Users — Authentication Accounts ─────────────────
// One row per login credential holder.
// ADR-036: person_id links every account to its human identity.
// ADR-055: domain tables use FK(platform_users) ONLY for auth/audit columns.
model PlatformUser {
  id            String        @id @db.Uuid
  personId      String        @unique @map("person_id") @db.Uuid
  accountStatus AccountStatus @default(ACTIVE) @map("account_status")
  accountType   AccountType   @default(HUMAN) @map("account_type")
  email         String        @unique
  displayName   String?       @map("display_name")
  avatarUrl     String?       @map("avatar_url")
  mfaEnabled    Boolean       @default(false) @map("mfa_enabled")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  lastSeenAt    DateTime?     @map("last_seen_at") @db.Timestamptz()

  person             IamPerson           @relation(fields: [personId], references: [id])
  federatedIdentities FederatedIdentity[]

  @@index([personId])
  @@index([email])
  @@map("platform_users")
  @@schema("platform")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  PENDING_VERIFICATION
  DEACTIVATED

  @@schema("platform")
}

enum AccountType {
  HUMAN
  SERVICE_ACCOUNT

  @@schema("platform")
}

// ── Platform Students — Student Identity Projection ──────────
// Portable across school transfers. Denormalised PII for zero-latency lookup.
// Authoritative identity lives in iam_person; this is a projection.
// Synced via person.identity.updated Kafka event (ADR-059).
model PlatformStudent {
  id               String    @id @db.Uuid
  personId         String    @unique @map("person_id") @db.Uuid
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  nationalIdHash   String?   @map("national_id_hash")
  isActive         Boolean   @default(true) @map("is_active")
  dataSubjectIsSelf Boolean  @default(false) @map("data_subject_is_self")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  person IamPerson @relation(fields: [personId], references: [id])

  @@index([nationalIdHash])
  @@map("platform_students")
  @@schema("platform")
}

// ── Platform Families — Cross-School Family Identity ─────────
// Enables cross-school sibling detection (tenant schemas cannot JOIN).
// Synced by FamilyMemberSyncWorker from sis_family_members events.
model PlatformFamily {
  id        String   @id @db.Uuid
  name      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  members FamilyMember[]

  @@map("platform_families")
  @@schema("platform")
}

// ── Family Members ───────────────────────────────────────────
model FamilyMember {
  id              String     @id @db.Uuid
  familyId        String     @map("family_id") @db.Uuid
  personId        String     @map("person_id") @db.Uuid
  memberRole      MemberRole @map("member_role")
  isPrimaryContact Boolean   @default(false) @map("is_primary_contact")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  family PlatformFamily @relation(fields: [familyId], references: [id])
  person IamPerson      @relation(fields: [personId], references: [id])

  @@unique([familyId, personId])
  @@index([personId])
  @@map("platform_family_members")
  @@schema("platform")
}

enum MemberRole {
  PARENT
  GUARDIAN
  STUDENT
  SIBLING
  OTHER

  @@schema("platform")
}

// ── Volunteer Profiles (ADR-032) ─────────────────────────────
// Cross-school visibility via direct platform schema read.
model VolunteerProfile {
  id                    String              @id @db.Uuid
  personId              String              @unique @map("person_id") @db.Uuid
  accountId             String?             @map("account_id") @db.Uuid
  phone                 String?
  backgroundCheckStatus BackgroundCheckStatus? @map("background_check_status")
  backgroundCheckRef    String?             @map("background_check_ref")
  backgroundCheckDate   DateTime?           @map("background_check_date") @db.Date
  certifications        Json?               @db.JsonB
  availabilityNotes     String?             @map("availability_notes")
  isActive              Boolean             @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  person IamPerson @relation(fields: [personId], references: [id])

  @@map("platform_volunteer_profiles")
  @@schema("platform")
}

// ── Substitute Profiles (ADR-014) ────────────────────────────
// Cross-school visibility. Substitute availability and credentials.
model SubstituteProfile {
  id                    String              @id @db.Uuid
  personId              String              @unique @map("person_id") @db.Uuid
  accountId             String?             @map("account_id") @db.Uuid
  phone                 String?
  backgroundCheckStatus BackgroundCheckStatus? @map("background_check_status")
  backgroundCheckRef    String?             @map("background_check_ref")
  backgroundCheckDate   DateTime?           @map("background_check_date") @db.Date
  certifications        Json?               @db.JsonB
  subjectQualifications Json?               @map("subject_qualifications") @db.JsonB
  gradeRange            String?             @map("grade_range")
  maxDistanceMiles      Int?                @map("max_distance_miles")
  dailyRate             Decimal?            @map("daily_rate") @db.Decimal(8, 2)
  isActive              Boolean             @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  person IamPerson @relation(fields: [personId], references: [id])

  @@map("platform_substitute_profiles")
  @@schema("platform")
}

enum BackgroundCheckStatus {
  PENDING
  PASSED
  FLAGGED
  EXPIRED

  @@schema("platform")
}

// ── Identity Provider Configuration ──────────────────────────
// Each school can have its own IdP (Google, Microsoft, SAML, etc.)
model IdentityProvider {
  id                    String       @id @db.Uuid
  schoolId              String?      @map("school_id") @db.Uuid
  name                  String
  providerType          ProviderType @map("provider_type")
  issuerUrl             String?      @map("issuer_url")
  clientIdEncrypted     String?      @map("client_id_encrypted")
  metadataUrl           String?      @map("metadata_url")
  isActive              Boolean      @default(true) @map("is_active")
  trustLevel            TrustLevel   @default(MEDIUM) @map("trust_level")
  autoProvisionAccounts Boolean      @default(false) @map("auto_provision_accounts")
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  school              School?             @relation(fields: [schoolId], references: [id])
  federatedIdentities FederatedIdentity[]

  @@map("iam_identity_provider")
  @@schema("platform")
}

enum ProviderType {
  GOOGLE
  MICROSOFT
  SAML
  OIDC
  LOCAL
  LDAP

  @@schema("platform")
}

enum TrustLevel {
  HIGH
  MEDIUM
  LOW

  @@schema("platform")
}

// ── Federated Identity — IdP-to-Account Mapping ──────────────
// Links external IdP identities to platform_users accounts.
model FederatedIdentity {
  id           String      @id @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  providerId   String      @map("provider_id") @db.Uuid
  externalId   String      @map("external_id")
  externalEmail String?    @map("external_email")
  syncStatus   SyncStatus  @default(SYNCED) @map("sync_status")
  conflictNote String?     @map("conflict_note")
  lastSyncAt   DateTime?   @map("last_sync_at") @db.Timestamptz()
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  user     PlatformUser     @relation(fields: [userId], references: [id])
  provider IdentityProvider @relation(fields: [providerId], references: [id])

  @@unique([providerId, externalId])
  @@index([userId])
  @@map("iam_federated_identity")
  @@schema("platform")
}

enum SyncStatus {
  SYNCED
  CONFLICT
  PENDING

  @@schema("platform")
}


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// STEP 6 — IAM Core (ADR-036)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ── Roles ────────────────────────────────────────────────────
// Named collections of permissions. System roles seeded at provisioning.
// Schools create custom roles (e.g. Department Head).
model Role {
  id          String  @id @db.Uuid
  schoolId    String? @map("school_id") @db.Uuid
  name        String
  description String?
  isSystem    Boolean @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  rolePermissions RolePermission[]
  assignments     IamRoleAssignment[]

  @@unique([schoolId, name])
  @@map("roles")
  @@schema("platform")
}

// ── Permissions ──────────────────────────────────────────────
// Resource:action pairs. e.g. att-001:read, att-001:write, att-001:admin
// All @RequirePermission checks use these codes, never role names.
model Permission {
  id          String  @id @db.Uuid
  code        String  @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  rolePermissions RolePermission[]

  @@index([resource, action])
  @@map("permissions")
  @@schema("platform")
}

// ── Role-Permission Mapping ──────────────────────────────────
model RolePermission {
  id           String @id @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
  @@schema("platform")
}

// ── Scope Types ──────────────────────────────────────────────
// Fixed vocabulary: PLATFORM, DISTRICT, SCHOOL, DEPARTMENT, CLASS, ACTIVITY
model IamScopeType {
  id               String  @id @db.Uuid
  code             String  @unique
  label            String
  allowsChildScopes Boolean @default(true) @map("allows_child_scopes")
  isSystem         Boolean @default(true) @map("is_system")

  scopes IamScope[]

  @@map("iam_scope_type")
  @@schema("platform")
}

// ── Scopes ───────────────────────────────────────────────────
// A specific instance: e.g. "Lincoln Elementary" (SCHOOL scope),
// "Math Department" (DEPARTMENT scope), "Period 3 Algebra" (CLASS scope)
model IamScope {
  id            String   @id @db.Uuid
  scopeTypeId   String   @map("scope_type_id") @db.Uuid
  entityId      String   @map("entity_id") @db.Uuid
  entityTable   String   @map("entity_table")
  label         String
  parentScopeId String?  @map("parent_scope_id") @db.Uuid
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  scopeType    IamScopeType       @relation(fields: [scopeTypeId], references: [id])
  parentScope  IamScope?          @relation("ScopeHierarchy", fields: [parentScopeId], references: [id])
  childScopes  IamScope[]         @relation("ScopeHierarchy")
  assignments  IamRoleAssignment[]
  accessCache  IamEffectiveAccessCache[]

  @@unique([scopeTypeId, entityId])
  @@index([parentScopeId])
  @@index([entityId])
  @@map("iam_scope")
  @@schema("platform")
}

// ── Role Assignments ─────────────────────────────────────────
// The sole mechanism for granting access. Always scoped + time-bounded.
model IamRoleAssignment {
  id               String           @id @db.Uuid
  accountId        String           @map("account_id") @db.Uuid
  roleId           String           @map("role_id") @db.Uuid
  scopeId          String           @map("scope_id") @db.Uuid
  effectiveFrom    DateTime         @default(now()) @map("effective_from") @db.Timestamptz()
  effectiveTo      DateTime?        @map("effective_to") @db.Timestamptz()
  status           AssignmentStatus @default(ACTIVE)
  source           AssignmentSource
  sourceRefId      String?          @map("source_ref_id") @db.Uuid
  assignedBy       String?          @map("assigned_by") @db.Uuid
  approvalRequestId String?         @map("approval_request_id") @db.Uuid
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  role  Role     @relation(fields: [roleId], references: [id])
  scope IamScope @relation(fields: [scopeId], references: [id])

  @@index([accountId, status])
  @@index([scopeId, roleId, status])
  @@index([effectiveTo])
  @@map("iam_role_assignment")
  @@schema("platform")
}

enum AssignmentStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED

  @@schema("platform")
}

enum AssignmentSource {
  MANUAL
  HR_SYNC
  SIS_DERIVED
  GUARDIAN_RELATIONSHIP
  WORKFLOW_APPROVAL
  EMERGENCY

  @@schema("platform")
}

// ── Role Assignment History ──────────────────────────────────
// Immutable audit of every state change on an assignment.
model IamRoleAssignmentHistory {
  id                String            @id @db.Uuid
  assignmentId      String            @map("assignment_id") @db.Uuid
  changedBy         String?           @map("changed_by") @db.Uuid
  changeType        AssignmentChangeType @map("change_type")
  previousStatus    AssignmentStatus? @map("previous_status")
  newStatus         AssignmentStatus? @map("new_status")
  previousEffectiveTo DateTime?       @map("previous_effective_to") @db.Timestamptz()
  newEffectiveTo    DateTime?         @map("new_effective_to") @db.Timestamptz()
  reason            String?
  changedAt         DateTime          @map("changed_at") @db.Timestamptz()

  @@index([assignmentId, changedAt])
  @@map("iam_role_assignment_history")
  @@schema("platform")
}

enum AssignmentChangeType {
  CREATED
  ACTIVATED
  SUSPENDED
  REVOKED
  EXPIRED
  EXTENDED
  SOURCE_UPDATED

  @@schema("platform")
}

// ── Relationship Access Rules ────────────────────────────────
// How person-to-person relationships translate into access grants.
// e.g. "Guardian of student → Parent Portal role at student's school"
model IamRelationshipAccessRule {
  id               String   @id @db.Uuid
  relationshipType String   @map("relationship_type")
  targetRoleId     String   @map("target_role_id") @db.Uuid
  scopeDerivation  String   @map("scope_derivation")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("iam_relationship_access_rule")
  @@schema("platform")
}

// ── Effective Access Cache ───────────────────────────────────
// Materialized permission set per account per scope.
// The SOLE source for hot-path permission checks (ADR-036).
// Direct JOINs across assignment→role→permission are FORBIDDEN on request path.
model IamEffectiveAccessCache {
  id                   String   @id @db.Uuid
  accountId            String   @map("account_id") @db.Uuid
  scopeId              String   @map("scope_id") @db.Uuid
  permissionCodes      String[] @map("permission_codes")
  computedAt           DateTime @map("computed_at") @db.Timestamptz()
  assignmentVersionHash String  @map("assignment_version_hash")

  scope IamScope @relation(fields: [scopeId], references: [id])

  @@unique([accountId, scopeId])
  @@index([accountId])
  @@map("iam_effective_access_cache")
  @@schema("platform")
}

// ── Access Change Events ─────────────────────────────────────
// IAM-specific immutable audit log. Every grant, revoke, status change.
model IamAccessChangeEvent {
  id           String              @id @db.Uuid
  accountId    String              @map("account_id") @db.Uuid
  eventType    AccessChangeEventType @map("event_type")
  actorId      String?             @map("actor_id") @db.Uuid
  scopeId      String?             @map("scope_id") @db.Uuid
  roleId       String?             @map("role_id") @db.Uuid
  assignmentId String?             @map("assignment_id") @db.Uuid
  metadata     Json?               @db.JsonB
  eventAt      DateTime            @map("event_at") @db.Timestamptz()

  @@index([accountId, eventAt(sort: Desc)])
  @@index([eventType, eventAt(sort: Desc)])
  @@map("iam_access_change_event")
  @@schema("platform")
}

enum AccessChangeEventType {
  ACCOUNT_CREATED
  ACCOUNT_SUSPENDED
  ACCOUNT_REACTIVATED
  ACCOUNT_LOCKED
  ROLE_GRANTED
  ROLE_REVOKED
  ROLE_SUSPENDED
  ROLE_EXPIRED
  GUARDIAN_ACCESS_PROVISIONED
  GUARDIAN_ACCESS_REVOKED
  MFA_ENROLLED
  MFA_REMOVED
  EMERGENCY_ACCESS_GRANTED
  EMERGENCY_ACCESS_REVOKED

  @@schema("platform")
}

// ── Auth Events ──────────────────────────────────────────────
// Authentication-specific events. Separate from access changes.
model IamAuthEvent {
  id            String        @id @db.Uuid
  accountId     String?       @map("account_id") @db.Uuid
  providerId    String?       @map("provider_id") @db.Uuid
  eventType     AuthEventType @map("event_type")
  ipAddressHash String?       @map("ip_address_hash")
  userAgentHash String?       @map("user_agent_hash")
  sessionId     String?       @map("session_id") @db.Uuid
  failureReason String?       @map("failure_reason")
  eventAt       DateTime      @map("event_at") @db.Timestamptz()

  @@index([accountId, eventAt(sort: Desc)])
  @@index([eventType, eventAt(sort: Desc)])
  @@map("iam_auth_event")
  @@schema("platform")
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  MFA_CHALLENGE_ISSUED
  MFA_CHALLENGE_PASSED
  MFA_CHALLENGE_FAILED
  SESSION_CREATED
  SESSION_TERMINATED
  TOKEN_REFRESHED
  TOKEN_REVOKED
  ACCOUNT_LOCKED_AUTO

  @@schema("platform")
}

// ── Service Principals ───────────────────────────────────────
// Machine identities for service-to-service auth.
model IamServicePrincipal {
  id          String   @id @db.Uuid
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("iam_service_principal")
  @@schema("platform")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CYCLE 3 STEP 3 — Communications Platform Support
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ── Push Tokens ──────────────────────────────────────────────
// One row per (user, device). Cross-tenant by design — a single
// platform_user can hold roles in multiple schools and we want
// one push registration to reach them everywhere they have access.
// Soft FK to platform_users (no DB FK per ADR-001/020 — kept loose
// so a deleted account doesn't cascade through device records).
model PlatformPushToken {
  id             String       @id @db.Uuid
  platformUserId String       @map("platform_user_id") @db.Uuid
  deviceId       String       @map("device_id")
  platform       PushPlatform
  token          String
  isActive       Boolean      @default(true) @map("is_active")
  lastSeenAt     DateTime?    @map("last_seen_at") @db.Timestamptz()
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([platformUserId, deviceId])
  @@index([platformUserId, isActive])
  @@index([token])
  @@map("platform_push_tokens")
  @@schema("platform")
}

enum PushPlatform {
  IOS
  ANDROID
  WEB

  @@schema("platform")
}

// ── Dead Letter Queue ────────────────────────────────────────
// Kafka messages that failed every consumer retry. Holds the raw
// payload + headers so an operator can replay or triage. Cross-tenant
// because a DLQ row may originate from any tenant, the operator is
// platform-scoped, and the failure handler runs above the request path.
model PlatformDlqMessage {
  id            String    @id @db.Uuid
  topic         String
  partition     Int
  kafkaOffset   BigInt    @map("kafka_offset")
  consumerGroup String    @map("consumer_group")
  eventId       String?   @map("event_id")
  tenantId      String?   @map("tenant_id") @db.Uuid
  payload       Json      @db.JsonB
  headers       Json?     @db.JsonB
  errorMessage  String    @map("error_message")
  errorClass    String?   @map("error_class")
  retryCount    Int       @default(0) @map("retry_count")
  firstFailedAt DateTime  @default(now()) @map("first_failed_at") @db.Timestamptz()
  lastFailedAt  DateTime  @default(now()) @map("last_failed_at") @db.Timestamptz()
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz()
  resolvedBy    String?   @map("resolved_by") @db.Uuid
  resolution    String?

  @@index([topic, lastFailedAt(sort: Desc)])
  @@index([consumerGroup, lastFailedAt(sort: Desc)])
  @@index([tenantId, lastFailedAt(sort: Desc)])
  @@index([resolvedAt])
  @@map("platform_dlq_messages")
  @@schema("platform")
}

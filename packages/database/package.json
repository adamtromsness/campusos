{
  "name": "@campusos/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm run generate && tsc --project tsconfig.json",
    "clean": "rm -rf dist",
    "migrate": "prisma migrate dev --schema=prisma/platform/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/platform/schema.prisma",
    "migrate:reset": "prisma migrate reset --schema=prisma/platform/schema.prisma --force",
    "generate": "prisma generate --schema=prisma/platform/schema.prisma",
    "seed": "tsx src/seed.ts",
    "seed:sis": "tsx src/seed-sis.ts",
    "seed:classroom": "tsx src/seed-classroom.ts",
    "seed:messaging": "tsx src/seed-messaging.ts",
    "seed:hr": "tsx src/seed-hr.ts",
    "seed:scheduling": "tsx src/seed-scheduling.ts",
    "seed:enrollment": "tsx src/seed-enrollment.ts",
    "seed:payments": "tsx src/seed-payments.ts",
    "seed:profile": "tsx src/seed-profile.ts",
    "seed:tasks": "tsx src/seed-tasks.ts",
    "seed:tickets": "tsx src/seed-tickets.ts",
    "seed:behaviour": "tsx src/seed-behaviour.ts",
    "seed:health": "tsx src/seed-health.ts",
    "provision": "tsx src/provision-tenant.ts",
    "studio": "prisma studio --schema=prisma/platform/schema.prisma",
    "lint": "eslint src/",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "dotenv": "^17.4.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@campusos/eslint-config": "workspace:*",
    "@campusos/tsconfig": "workspace:*",
    "@types/node": "^20.19.39",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.0",
    "prisma": "^5.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
